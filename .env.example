SIP_USERNAME=your_sip_username
SIP_PASSWORD=your_sip_password
SIP_SERVER=sip.example.com:5060
SIP_CONNECTION_TYPE=UDP
SIP_CALLER_ID=
SIP_DESTINATION=your_phone_number

TTS_VOICE=en-US-AriaNeural
TTS_RATE=+0%
TTS_VOLUME=+0%
TTS_PITCH=+0Hz

# Maximum time to wait for the destination to answer. Playback uses the
# generated audio duration and is not limited by this value.
CALL_TIMEOUT_SECONDS=60
CALL_REPETITIONS=1
CALL_PAUSE_SECONDS=1

API_HOST=127.0.0.1
API_PORT=8080
LOG_LEVEL=INFO
